---
import { siteData } from "../data/site";
import I18nText from "./I18nText.astro";
const n = siteData.nav;
---

<header
  class="sticky top-0 z-50 backdrop-blur border-b border-neutral-200/40 dark:border-neutral-800/60"
>
  <nav class="mx-auto max-w-5xl flex items-center justify-between px-5 py-3">
    <a href="/" class="font-semibold tracking-tight">{siteData.name}</a>
    <div class="flex items-center gap-4 sm:gap-5 text-sm">
      <a href="/#home" class="hover:text-brand transition-colors">
        <I18nText zh={n.home.zh} en={n.home.en} />
      </a>
      <a href="/about" class="hover:text-brand transition-colors">
        <I18nText zh={n.about.zh} en={n.about.en} />
      </a>
      <a href="/#projects" class="hover:text-brand transition-colors">
        <I18nText zh={n.projects.zh} en={n.projects.en} />
      </a>
      <span class="opacity-40 cursor-not-allowed">
        <I18nText zh={n.blog.zh} en={n.blog.en} />
      </span>
      <button
        onclick="window.toggleTheme()"
        aria-label="toggle theme"
        class="rounded px-2 py-1 hover:bg-neutral-200/50 dark:hover:bg-neutral-800 transition-colors"
        >◐</button
      >
      <button
        onclick="window.setLang(document.documentElement.getAttribute('data-locale')==='en'?'zh':'en')"
        aria-label="toggle language"
        class="rounded px-2 py-1 hover:bg-neutral-200/50 dark:hover:bg-neutral-800 text-xs transition-colors"
        >中/EN</button
      >
    </div>
  </nav>
</header>
